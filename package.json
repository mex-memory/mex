{
  "name": "promexeus",
  "version": "0.3.1",
  "description": "CLI engine for mex scaffold — drift detection, pre-analysis, and targeted sync",
  "type": "module",
  "bin": {
    "mex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "scaffold",
    "drift-detection",
    "documentation",
    "cli",
    "claude",
    "cursor",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theDakshJaitly/mex.git"
  },
  "author": "Daksh Jaitly",
  "license": "MIT",
  "homepage": "https://github.com/theDakshJaitly/mex#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.36.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
